@page "/cart"

<div class="text-md font-[Roboto] text-zinc-800 font-light leading-normal overflow-hidden tracking-wide">
    <main class="main-content" role="main">
        <div class="py-12 px-8">
            <h1 class="pl-4 pb-8 ml-4 text-lg text-bold text-zinc-800 uppercase">
                Giỏ hàng
            </h1>
            <div class="w-full">
                <table class="mb-4">
                    <thead class="relative border-y-2 border-neutral-200">
                        <tr>
                            <th class="p-4 text-center leading-normal" colspan="2">
                                Sản phẩm
                            </th>
                            <th class="p-4 text-center leading-normal">Đơn giá</th>
                            <th class="p-4 text-center leading-normal">Số lượng</th>
                            <th class="p-4 text-center leading-normal">Tổng giá</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="relative border-t-2 border-neutral-200">
                            <td class="p-4 text-left">
                                <a href="/products">
                                    <img src="//product.hstatic.net/200000343865/product/6_4fda9c4d44814b78951d775bd8047cfe_medium.jpg"
                                         alt="Tý Quậy - Tập 6" />
                                </a>
                            </td>
                            <td class="p-4 text-left">
                                <a class="h4 block text-red-600 font-bold" href="/products">
                                    Tý Quậy - Tập 6
                                </a>

                                Khuyến mãi: 1017960497 - Giảm vô thời hạn 10% cho toàn bộ
                                Sách Kim Đồng

                                <br />

                                <a class="block text-red-600" href="/cart">
                                    <small>Xóa</small>
                                </a>
                            </td>
                            <td class="p-4 text-left">
                                <span class="text-3xl font-bold leading-normal">
                                    36,000₫
                                </span>
                            </td>
                            <td class="p-4 text-left">
                                <div class="mx-auto max-w-[150px] min-w-[75px]">
                                    <input class="block py-1 px-4 text-center w-full border-1 border-neutral-200"
                                           type="number"
                                           value="1"
                                           min="1" />
                                </div>
                            </td>
                            <td class="p-4 text-left">
                                <span class="text-3xl font-bold leading-normal">
                                    36,000₫
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div class="grid grid-cols-1 my-6 py-6 relative">
                    <div class="box-border float-left pl-6 align-top">
                        <label class="block cursor-pointer"
                               for="CartSpecialInstructions">Ghi chú</label>
                        <textarea class="w-full p-2 border-2 border-neutral-200"
                                  name="note"
                                  id="CartSpecialInstructions"></textarea>
                    </div>

                    <div class="pl-6 align-top text-right">
                        <p class="ml-2">
                            <span>Tạm tính:</span>
                            <span class="text-xl font-bold leading-normal">
                                36,000₫
                            </span>
                        </p>

                        <button class="py-1 px-4 text-white bg-red-600 text-center font-bold cursor-pointer">
                            Cập nhật
                        </button>
                        <button class="py-1 px-4 text-white bg-red-600 text-center font-bold cursor-pointer">
                            Thanh toán
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="modal @modalClass" tabindex="-1" role="dialog" style="display:@modalDisplay; overflow-y: auto;">
    <div class="quickview-cart"
         style="
        display: block;
        border-radius: 3px;
        transition: all 0.3s ease;
        text-align: left;
        z-index: 9999;
        top: 100px;
        right: 350px;
        width: 280px;
        padding: 5px;
        background: #fff;
        line-height: normal !important;
        box-shadow: 0 1px 7px 0 rgba(0, 0, 0, 0.35);
        position:  absolute;
      ">
        <h3 style="
          border-radius: 3px;
          overflow: hidden;
          padding: 5px;
          width: 100%;
          display: block;
          background: #d51c24;
          color: #fff;
          position: relative;
          font-size: 16px;
        ">
            Giỏ hàng của tôi (1 sản phẩm)

            <span @onclick="Close"
                  style="
            position: absolute;
            color: #fff;
            top: 5px;
            right: 5px;
            cursor: pointer;">
                &times;
            </span>
        </h3>
        <ul class="no-bullets" style="list-style: none outside; padding-top:5px;">
            <li class="cart-item"
                style="
            margin: 0px 0px 5px 0px;
            position: relative;
            border-bottom: 1px dashed #ddd;
            padding-bottom: 5px;
          ">
                <div class="grid mg-left-15">
                    <div class="grid__item large--four-twelfths medium--four-twelfths small--four-twelfths pd-left15"
                         style="
                box-sizing: border-box;
                float: left;
                min-height: 1px;
                vertical-align: top;
                width: 33.333%;
              ">
                        <div class="cart-item-img text-center"
                             style="padding-right: 15px">
                            <a href="/cart">
                                <img src="//product.hstatic.net/200000343865/product/6_4fda9c4d44814b78951d775bd8047cfe_small.jpg"
                                     alt="Tý Quậy - Tập 6" />
                            </a>
                        </div>
                    </div>
                    <div class="grid__item large--eight-twelfths medium--eight-twelfths small--eight-twelfths pd-left15">
                        <div class="cart-item-info text-left">
                            <a style="color: #333333; text-decoration: none; font-size: 12px"
                               href="/cart">Tý Quậy - Tập 6</a>
                        </div>
                        <div class="cart-item-price-quantity text-left"
                             style="color: #333333">
                            <span style="display:block; margin-bottom: 3px" class="quantity">Số lượng: 1</span>
                            <span style="display:block; margin-bottom: 3px" class="current-price">Giá/sp: 36,000₫</span>
                        </div>
                    </div>
                </div>
            </li>
        </ul>

        <div style="
          border-radius: 3px;
          overflow: hidden;
          margin: 5px 0px;
          padding: 5px;
          width: 100%;
          display: block;
          background: #f7f7f7;
          color: #333333;
        "
             class="qv-cart-total">
            Tạm tính: <span style="color: #d51c24">36,000₫</span>
        </div>
        <div style="box-sizing: border-box"
             class="quickview-cartactions clearfix">
            <a style="
            float: left;
            color: #d51c24;
            border: 1px solid #d51c24;
            border-radius: 3px;
            overflow: hidden;
            display: inline-block;
            width: 48%;
            text-align: center;
            padding: 5px 4px;
            text-transform: uppercase !important;
            font-size: 16px;
            text-decoration: none;
          "
               href="/cart">
                Xem giỏ hàng
            </a>
            <a href="/payment"
               style="
            float: right;
            color: #fff;
            border: 1px solid #d51c24;
            background: #d51c24;
            border-radius: 3px;
            overflow: hidden;
            display: inline-block;
            width: 48%;
            text-align: center;
            padding: 5px 10px;
            text-transform: uppercase !important;
            text-decoration: none;
          ">Thanh toán</a>
        </div>
    </div>
</div>

@if (showBackdrop)
{
    <div class="modal-backdrop fade show"></div>
}

@code {

    [Parameter]
    public RenderFragment? Title { get; set; }

    [Parameter]
    public RenderFragment? Body { get; set; }

    [Parameter]
    public RenderFragment? Footer { get; set; }

    public Guid Guid = Guid.NewGuid();

    private string modalDisplay = "none;";
    private string modalClass = "";
    private bool showBackdrop = false;

    public void Open()
    {
        modalDisplay = "block;";
        modalClass = "show";
        showBackdrop = true;
        StateHasChanged();
    }

    public void Close()
    {
        modalDisplay = "none";
        modalClass = "";
        showBackdrop = false;
        StateHasChanged();
    }
}
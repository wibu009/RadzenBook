    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" />
</MudIconButton>
<MudTextField @bind-Value="searchText" Placeholder="Tìm kiếm..." Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Secondary" Style="width:400px; height:40px;" />

@code {
